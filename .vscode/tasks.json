{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build api",
      "command": "dotnet",
      "type": "process",
      "args": [
        "build",
        "${workspaceFolder}/src/claudio-api/Claudio.Api.csproj",
        "/property:GenerateFullPaths=true",
        "/consoleloggerparameters:NoSummary"
      ],
      "problemMatcher": "$msCompile"
    },
    {
      "label": "build web",
      "type": "process",
      "command": "vp",
      "args": [
        "build"
      ],
      "options": {
        "cwd": "${workspaceFolder}/src/claudio-web"
      }
    },
    {
      "label": "build api with spa",
      "dependsOn": [
        "build web",
        "build api"
      ],
      "dependsOrder": "sequence"
    },
    {
      "label": "publish",
      "command": "dotnet",
      "type": "process",
      "args": [
        "publish",
        "${workspaceFolder}/src/claudio-api/Claudio.Api.csproj",
        "/property:GenerateFullPaths=true",
        "/consoleloggerparameters:NoSummary"
      ],
      "problemMatcher": "$msCompile"
    },
    {
      "label": "watch",
      "command": "dotnet",
      "type": "process",
      "args": [
        "watch",
        "run",
        "${workspaceFolder}/src/claudio-api/Claudio.Api.csproj",
        "/property:GenerateFullPaths=true",
        "/consoleloggerparameters:NoSummary"
      ],
      "problemMatcher": "$msCompile"
    },
    {
      "label": "tauri dev",
      "type": "npm",
      "script": "tauri:dev",
      "path": "src/claudio-web/",
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "panel": "shared",
        "showReuseMessage": false,
        "clear": true
      }
    },
    {
      "label": "API + Tauri",
      "dependsOn": [
        "watch",
        "tauri dev"
      ],
      "dependsOrder": "parallel"
    }
  ]
}
